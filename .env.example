# industry-analysis 子 skill 环境变量模板
#
# 用法:
#   1. cp .env.example .env
#   2. 把下面的占位值替换成真实 token
#   3. .env 已被 .gitignore,不会进 git
#
# 加载机制:
#   - Python 数据脚本(scripts/**/*.py)会通过 python-dotenv 自动从项目根目录的 .env 加载
#   - 也可以 source .env 在 shell 里加载(行首加 export 即可双兼容)

# Tushare PRO token(必需)
# 申请地址: https://tushare.pro/user/token
# 我们用到的接口:sw_daily / index_daily / daily / index_member_all / fina_indicator / daily_basic / hk_hold / margin_detail / cn_cpi / cn_ppi / cn_pmi / cn_m / shibor 等
# Q1=A 已确认: 你账号有 2000+ 积分,所有接口可用
export TUSHARE_TOKEN="your_tushare_pro_token_here"

# 可选:akshare 不需要 token,免费使用
# 可选:LOG_LEVEL(INFO / DEBUG / WARNING),默认 INFO
# export LOG_LEVEL="INFO"
